---
// Importamos el componente (Solución al TODO 1)
import RecursoCard from '../components/RecursoCard.astro';

const titulo = "Acerca de Astro Campus";
const descripcion = "Proyecto incremental para aprender Astro en el contexto de la materia.";

const equipo = [
  { nombre: "Pablo Torres", rol: "Docente", github: "PabloT18" },
];

const modoProduccion = import.meta.env.PROD;

// Arreglo de herramientas (Solución al TODO 2)
const herramientas = [
  { titulo: "Visual Studio Code", url: "https://code.visualstudio.com/", descripcion: "Editor de código fuente." },
  { titulo: "GitHub", url: "https://github.com/", descripcion: "Plataforma de alojamiento para desarrollo de software." },
  { titulo: "pnpm", url: "https://pnpm.io/", descripcion: "Gestor de paquetes rápido y eficiente." }
];
const mostrarHerramientas = herramientas.length > 0;
---

<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{titulo}</title>
</head>
<body>
  <main>
    <h1>{titulo}</h1>
    <p>{descripcion}</p>

    <h2>Equipo</h2>
    <ul>
      {equipo.map(p => (
        <li>
          <strong>{p.nombre}</strong> - {p.rol} 
          <a href={`https://github.com/${p.github}`} target="_blank" rel="noopener">
            (GitHub)
          </a>
        </li>
      ))}
    </ul>

    <!-- Renderizado de las herramientas (Solución al TODO 3 y 4) -->
    <section>
      <h2>Herramientas</h2>
      {mostrarHerramientas && (
        <div>
          {herramientas.map(h => (
            <RecursoCard titulo={h.titulo} url={h.url} descripcion={h.descripcion} />
          ))}
        </div>
      )}
      {!mostrarHerramientas && <p>No hay herramientas disponibles.</p>}
    </section>

    <!-- Avisos de entorno[cite: 3] -->
    {modoProduccion && (
      <p style="color: #22c55e; font-size: 0.8rem;">Versión de producción activa.</p>
    )}
    {!modoProduccion && (
      <p style="color: #f59e0b; font-size: 0.8rem;">Modo desarrollo - usa <code>pnpm build</code> para producción.</p>
    )}

    <nav>
      <a href="/">&larr; Inicio</a>
    </nav>
  </main>
</body>
</html>

<style is:global>
  body {
    font-family: system-ui, sans-serif;
    max-width: 800px;
    margin: 0 auto;
    padding: 2rem;
    background: #0f0f0f;
    color: #e8e8e8;
  }
  h1 { color: #FF5D01; }
  a { color: #FF5D01; }
  li { margin-bottom: 0.5rem; }
</style>